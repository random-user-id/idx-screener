# ── OneSignal Push Notification ──────────────────────────────
# Daftar gratis di https://onesignal.com
# Buat Web Push app → copy App ID dan REST API Key
ONESIGNAL_APP_ID=your-onesignal-app-id-here
ONESIGNAL_API_KEY=your-onesignal-rest-api-key-here

# ── App Config ────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO
